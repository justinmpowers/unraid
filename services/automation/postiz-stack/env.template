# ------------------------------------------------------------
# Global host settings
# ------------------------------------------------------------
TZ=America/New_York
HOST_HOSTNAME=UNRAID-HOST
DOMAIN=example.local
APPDATA_PATH=/mnt/user/appdata

# ------------------------------------------------------------
# Postiz core
# IMPORTANT: set explicit pinned image tags or digests.
# ------------------------------------------------------------
POSTIZ_API_IMAGE=ghcr.io/gitroomhq/postiz-api:latest
POSTIZ_FRONTEND_IMAGE=ghcr.io/gitroomhq/postiz-frontend:latest
POSTIZ_JWT_SECRET=replace_with_long_random_secret
POSTIZ_DB_NAME=postiz-db-local
POSTIZ_DB_USER=postiz-user
POSTIZ_DB_PASSWORD=replace_with_db_password
POSTIZ_TEMPORAL_DB_NAME=postiz_temporal
POSTIZ_API_HEALTH_PATH=/health
POSTIZ_FRONTEND_HEALTH_PATH=/

# ------------------------------------------------------------
# n8n core
# ------------------------------------------------------------
N8N_ENCRYPTION_KEY=replace_with_long_random_secret

# ------------------------------------------------------------
# Workflow runtime vars for n8n templates
# ------------------------------------------------------------
ETSY_SHOP_ID=12345678
ETSY_CLIENT_ID=your_etsy_client_id
ETSY_ACCESS_TOKEN=your_etsy_oauth_access_token
TELEGRAM_APPROVAL_CHAT_ID=123456789
POSTIZ_BASE_URL=http://postiz-api:3000
OLLAMA_BASE_URL=http://ollama:11434

# ------------------------------------------------------------
# Etsy draft creator utility (scripts/etsy-draft-creator.js)
# ------------------------------------------------------------
ETSY_API_BASE_URL=https://openapi.etsy.com
ETSY_LISTING_QUANTITY=1
ETSY_LISTING_TITLE=Draft Listing Title
ETSY_LISTING_DESCRIPTION=Draft listing created programmatically for approval.
ETSY_LISTING_PRICE=10
ETSY_WHO_MADE=i_did
ETSY_WHEN_MADE=made_to_order
ETSY_TAXONOMY_ID=1429
ETSY_SHIPPING_PROFILE_ID=0
ETSY_LISTING_IMAGE_PATH=/mnt/user/path/to/listing-image.jpg
DRY_RUN=true

# ------------------------------------------------------------
# API integration placeholders for OAuth orchestration
# ------------------------------------------------------------
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=
PINTEREST_REDIRECT_URI=
