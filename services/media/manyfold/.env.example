# Manyfold - 3D Model Library
# Environment Configuration for Unraid Deployment

# System Configuration
TZ=America/New_York
PUID=99
PGID=100

# Application paths
APPDATA_PATH=/mnt/user/appdata
MANYFOLD_MODELS_PATH=/mnt/user/data/models

# ============================================
# MANYFOLD CONFIGURATION
# ============================================
MANYFOLD_SECRET_KEY_BASE=your_secret_key_here

# Database
MANYFOLD_DATABASE_ADAPTER=postgresql
MANYFOLD_DATABASE_HOST=manyfold-postgres
MANYFOLD_DATABASE_PORT=5432
MANYFOLD_DATABASE_USER=manyfold
MANYFOLD_DATABASE_PASSWORD=changeme
MANYFOLD_DATABASE_NAME=manyfold

# Redis
MANYFOLD_REDIS_URL=redis://manyfold-redis:6379/1

# Public access
MANYFOLD_PUBLIC_HOSTNAME=manyfold.yourdomain.com
MANYFOLD_PUBLIC_PORT=443

# Features
MANYFOLD_MULTIUSER=enabled
MANYFOLD_HTTPS_ONLY=enabled

# ============================================
# AUTHENTIK OIDC CONFIGURATION
# ============================================
# In Authentik: create an OAuth2/OIDC Provider, then create an Application.
# Set the redirect URI to: https://<MANYFOLD_PUBLIC_HOSTNAME>/users/auth/openid_connect/callback

# Client ID from the Authentik OAuth2 Provider
MANYFOLD_OIDC_CLIENT_ID=your_client_id_here

# Client Secret from the Authentik OAuth2 Provider
MANYFOLD_OIDC_CLIENT_SECRET=your_client_secret_here

# Issuer URL - found in Authentik under the provider's OpenID Configuration
# Format: https://auth.yourdomain.com/application/o/<slug>/
MANYFOLD_OIDC_ISSUER=https://auth.yourdomain.com/application/o/manyfold/

# Label shown on the login button (default: Authentik)
MANYFOLD_OIDC_NAME=Authentik

# Set to "enabled" to disable local accounts and require Authentik login
MANYFOLD_FORCE_OIDC=disabled
