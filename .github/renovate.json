{\n  "$schema": "https://docs.renovatebot.com/renovate-schema.json",\n  "extends": [\n    "config:recommended"\n  ],\n  "dependencyDashboard": true,\n  "labels": [\n    "automated",\n    "container-updates",\n    "infrastructure"\n  ],\n  "branchPrefix": "renovate/",\n  "timezone": "UTC",\n  "baseBranchPatterns": [\n    "main"\n  ],\n  "recreateWhen": "always",\n  "rebaseWhen": "conflicted",\n  "rangeStrategy": "pin",\n  "respectLatest": true,\n  "enabledManagers": [\n    "docker-compose"\n  ],\n  "packageRules": [\n    {\n      "matchManagers": [\n        "docker-compose"\n      ],\n      "matchFileNames": [\n        "services/**/docker-compose.yml"\n      ],\n      "groupName": "Weekly container updates",\n      "groupSlug": "weekly-container-updates",\n      "separateMajorMinor": true,\n      "minimumReleaseAge": "1 day",\n      "commitMessagePrefix": "chore: ",\n      "commitMessageTopic": "{{depName}}",\n      "labels": [\n        "automated",\n        "container-updates",\n        "infrastructure"\n      ]\n    },\n    {\n      "matchUpdateTypes": [\n        "major"\n      ],\n      "labels": [\n        "breaking-change?"\n      ],\n      "prPriority": -1\n    }\n  ]\n}